# Copy this file to the repo root as .env.
# Never commit real API keys or private key files.

# Production:
KALSHI_BASE_URL=https://external-api.kalshi.com/trade-api/v2

# Demo:
# KALSHI_BASE_URL=https://external-api.demo.kalshi.co/trade-api/v2

KALSHI_API_KEY_ID=your-api-key-id
KALSHI_PRIVATE_KEY_PATH=/absolute/path/to/kalshi-api-key.key

# Required in addition to --live before any real order is submitted.
KALSHI_ALLOW_LIVE_TRADING=false
