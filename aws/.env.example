# AWS credentials. Prefer `aws configure` locally, but these env vars also work.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# AWS/CDK region/account.
AWS_REGION=us-east-1
CDK_DEFAULT_ACCOUNT=
CDK_DEFAULT_REGION=us-east-1

# Optional stable bucket name. Must be globally unique across S3.
# Runtime can also discover this from the CDK stack's BucketName output.
SPORTSBETTING_S3_BUCKET=ashwintayur-sportsbetting
SPORTSBETTING_STACK_NAME=SportsBettingStack

# Optional CDK context equivalents.
CDK_CONTEXT_projectName=sportsbetting
CDK_CONTEXT_bucketName=ashwintayur-sportsbetting
KALSHI_SECRET_NAME=sportsbetting/kalshi

# Vercel also needs AWS_REGION, SPORTSBETTING_S3_BUCKET, and AWS credentials so
# `/api/status` can read S3 through the project aws module.
